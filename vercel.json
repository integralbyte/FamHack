{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/registration/status",
      "destination": "/api/config?mode=registration-status"
    },
    {
      "source": "/api/registration/complete",
      "destination": "/api/config?mode=registration-complete"
    },
    {
      "source": "/R2FzdGVy==",
      "destination": "/api/config?mode=page&slug=easter"
    },
    {
      "source": "/about",
      "destination": "/api/config?mode=page&slug=about"
    },
    {
      "source": "/about.html",
      "destination": "/api/config?mode=page&slug=about"
    },
    {
      "source": "/tracks",
      "destination": "/api/config?mode=page&slug=tracks"
    },
    {
      "source": "/tracks.html",
      "destination": "/api/config?mode=page&slug=tracks"
    },
    {
      "source": "/register",
      "destination": "/api/config?mode=page&slug=register"
    },
    {
      "source": "/register.html",
      "destination": "/api/config?mode=page&slug=register"
    },
    {
      "source": "/join",
      "destination": "/api/config?mode=page&slug=join"
    },
    {
      "source": "/join.html",
      "destination": "/api/config?mode=page&slug=join"
    },
    {
      "source": "/dashboard",
      "destination": "/api/config?mode=page&slug=dashboard"
    },
    {
      "source": "/dashboard.html",
      "destination": "/api/config?mode=page&slug=dashboard"
    },
    {
      "source": "/ctf",
      "destination": "/api/config?mode=page&slug=ctf"
    },
    {
      "source": "/ctf.html",
      "destination": "/api/config?mode=page&slug=ctf"
    }
  ],
  "functions": {
    "api/config.js": {
      "includeFiles": "api/_lib/launch-pages/**"
    }
  }
}
